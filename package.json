{
  "name": "mcti",
  "private": false,
  "version": "1.0.0",
  "description": "A Minecraft mob personality test inspired by MBTI.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:pages": "tsc && vite build --base=./",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "audit:wiki": "node scripts/audit-wiki-details.mjs",
    "validate:mobs": "node scripts/validate-mobs.mjs",
    "validate:coverage": "node scripts/validate-coverage.mjs"
  },
  "devDependencies": {
    "jsdom": "^29.1.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
